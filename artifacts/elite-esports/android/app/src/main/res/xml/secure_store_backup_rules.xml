<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup rules for expo-secure-store.
  Excludes all secure/sensitive data from Android Auto Backup (Android 11 and below).
  Referenced by android:fullBackupContent in AndroidManifest.xml.
-->
<full-backup-content>
  <exclude domain="sharedpref" path="."/>
  <exclude domain="database"   path="."/>
  <exclude domain="root"       path="."/>
  <exclude domain="file"       path="."/>
  <exclude domain="external"   path="."/>
</full-backup-content>

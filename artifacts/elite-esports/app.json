{
  "expo": {
    "name": "Elite eSports",
    "slug": "elite-esports",
    "version": "2.5.1",
    "owner": "avzio-expo",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "elite-esports",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.elite.esports.android",
      "googleServicesFile": "./google-services.json",
      "versionCode": 2,
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FE4C11",
          "defaultChannel": "elite-esports-default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Elite eSports uses your location to find nearby tournaments and match you with local competitors.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-background-fetch",
      "expo-task-manager"
    ],
    "extra": {
      "eas": {
        "projectId": "76a1d1cf-d260-4bc6-bec6-a1da46bb819d"
      },
      "admob": {
        "androidAppId": "ca-app-pub-2219438935030744~5831569923"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}

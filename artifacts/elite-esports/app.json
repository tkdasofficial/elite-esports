{
  "expo": {
    "name": "Elite eSports",
    "slug": "elite-esports",
    "version": "1.0.0",
    "owner": "avzio-expo",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "elite-esports",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.elite.esports.ios",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Elite eSports uses your location to show nearby tournaments and match you with local competitors.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Elite eSports uses your location to show nearby tournaments and match you with local competitors.",
        "NSUserNotificationUsageDescription": "Elite eSports sends match alerts, tournament updates, reward notifications, and account security alerts to keep you in the game."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.elite.esports.android",
      "versionCode": 1,
      "compileSdkVersion": 36,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FE4C11",
          "defaultChannel": "elite-esports-default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Elite eSports uses your location to show nearby tournaments and match you with local competitors.",
          "locationAlwaysAndWhenInUsePermission": "Elite eSports uses your location to show nearby tournaments and match you with local competitors.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2219438935030744~5831569923",
          "iosAppId": "ca-app-pub-2219438935030744~5831569923",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
          "skAdNetworkItems": [
            { "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork" },
            { "SKAdNetworkIdentifier": "4fzdc2evr5.skadnetwork" },
            { "SKAdNetworkIdentifier": "2fnua5tdw4.skadnetwork" }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "76a1d1cf-d260-4bc6-bec6-a1da46bb819d"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}

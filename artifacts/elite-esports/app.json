{
  "expo": {
    "name": "Elite eSports",
    "slug": "elite-esports",
    "version": "1.0.0",
    "owner": "avzio",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "elite-esports",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.elite.esports.ios",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Elite eSports uses your location to find nearby tournaments and match you with local competitors.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Elite eSports uses your location to find nearby tournaments and match you with local competitors.",
        "NSUserNotificationUsageDescription": "Elite eSports sends match alerts, tournament updates, reward notifications, and account security alerts to keep you in the game."
      }
    },
    "android": {
      "package": "com.elite.esports.android",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "compileSdkVersion": 36,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FE4C11",
          "defaultChannel": "elite-esports-default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Elite eSports uses your location to find nearby tournaments and match you with local competitors.",
          "locationAlwaysAndWhenInUsePermission": "Elite eSports uses your location to find nearby tournaments and match you with local competitors.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2219438935030744~5831569923",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6a10f6c8-fa7b-46be-bb86-98328356c220"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}

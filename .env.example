# Supabase configuration for the Elite eSports Expo mobile app.
# All environment variables exposed to the app must use the EXPO_PUBLIC_ prefix.
# Copy this file to .env and fill in your values.

EXPO_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your-key-here"
EXPO_PUBLIC_SUPABASE_PROJECT_ID="your-project-id"

# Optional: Admin email address (grants admin role on login)
EXPO_PUBLIC_ADMIN_EMAIL="admin@yourdomain.com"
